############################################
# DeepSciPaper Research Copilot (.env)
# Copy to `.env` and fill values as needed.
############################################

# ---- Cloud keys (optional; only needed if you use Cloud API backend) ----
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Optional: OpenAI-compatible base URL (leave blank for OpenAI default)
OPENAI_BASE_URL=

# ---- Tavily (recommended for higher-quality web search via gpt-researcher) ----
TAVILY_API_KEY=

# ---- Local LLM (Ollama) ----
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=gpt-oss:20b
DEFAULT_EMBEDDING_MODEL=bge-m3:567m

# ---- Research Copilot defaults ----
WORKSPACE_TITLE=Patent Classification into SDGs

# Retrieval controls
MAX_SEARCH_RESULTS_PER_QUERY=12
SOURCE_VALIDATION_LIMIT=80
PDF_DOWNLOAD_LIMIT=15

# Deep research controls
DEEP_RESEARCH_BREADTH=3
DEEP_RESEARCH_DEPTH=2
DEEP_RESEARCH_CONCURRENCY=3

# LLM generation controls
TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_MAX_TOKENS=6000
LLM_TIMEOUT_SECONDS=120

# Multimodal agentic RAG controls
MULTIMODAL_STORE_DIR=./multimodal_store
MULTIMODAL_QDRANT_COLLECTION=deepscipaper_multimodal
MULTIMODAL_TEXT_MODEL=gemma4:latest
MULTIMODAL_IMAGE_MODEL=gemma4:latest
MULTIMODAL_EMBED_MODEL=sentence-transformers/all-mpnet-base-v2
MINERU_BACKEND=pipeline
MINERU_METHOD=auto
MINERU_LANG=en

# ---- Paths (optional) ----
BIB_PDF_DIR=./bib_pdf
COMPILED_OUTPUT_DIR=./compiled_output
PAPER_TEX_PATH=./paper.tex
